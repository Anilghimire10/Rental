# ============================================================================
# GharBhada — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Project URL + anon (public) key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service-role key — SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC_,
# never import into a client component. Used for admin operations + seed script.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# Direct Postgres connection string (used by the seed script only).
# Supabase Dashboard → Project Settings → Database → Connection string.
SUPABASE_DB_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres"

# --- App --------------------------------------------------------------------
# Public site URL (used for OAuth redirects + email links). No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Agency contact (shown PUBLICLY on listings — platform, NOT owner) -------
NEXT_PUBLIC_AGENCY_PHONE="+9779800000000"
NEXT_PUBLIC_AGENCY_WHATSAPP="9779800000000"
NEXT_PUBLIC_AGENCY_EMAIL="hello@gharbhada.com"

# --- Mapbox -----------------------------------------------------------------
# Public token (pk.*) — restrict it to your domains in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-public-token"

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY="re_your_resend_api_key"
# Verified sender + the inbox that receives new-inquiry notifications.
EMAIL_FROM="GharBhada <noreply@yourdomain.com>"
ADMIN_NOTIFICATION_EMAIL="admin@yourdomain.com"

# --- Seed script (creates the first admin) ----------------------------------
SEED_ADMIN_EMAIL="admin@gharbhada.test"
SEED_ADMIN_PASSWORD="ChangeMe!Admin123"
